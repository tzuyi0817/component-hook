{
  "name": "@component-hook/eslint-plugin",
  "type": "module",
  "version": "1.4.4",
  "packageManager": "pnpm@11.11.0",
  "description": "ESLint config for component hook",
  "author": "Tzuyi",
  "license": "MIT",
  "homepage": "https://github.com/tzuyi0817/component-hook/tree/master/packages/eslint-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzuyi0817/component-hook.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/tzuyi0817/component-hook/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "tag": "latest"
  },
  "scripts": {
    "dev": "eslint-config-inspector --config ../../eslint.config.js",
    "build": "pnpm run build:typegen && tsdown",
    "build:typegen": "node scripts/typegen.ts",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "eslint": "catalog:"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^9.39.4",
    "@eslint/markdown": "^8.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.6.0",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "typescript-eslint": "^8.63.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^3.0.4",
    "@types/eslint-plugin-security": "^3.0.1",
    "eslint-typegen": "^2.3.1"
  }
}
